{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "AI_HARNESS_AUDIO_DIR=\"$(git rev-parse --show-toplevel)/06_skills/ai-harness/audio\" node \"$(git rev-parse --show-toplevel)/06_skills/ai-harness/claude/hooks/play-sound.mjs\" session_start",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "AI_HARNESS_AUDIO_DIR=\"$(git rev-parse --show-toplevel)/06_skills/ai-harness/audio\" node \"$(git rev-parse --show-toplevel)/06_skills/ai-harness/claude/hooks/play-sound.mjs\" post_tool_use",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
